# ML Service Environment Variables
# Copy to .env and customize for your service:
#   cp .env.example .env

# ─────────────────────────────────────────────
# Reproducibility
# ─────────────────────────────────────────────
SEED=42
PYTHONHASHSEED=42

# ─────────────────────────────────────────────
# Service Configuration
# ─────────────────────────────────────────────
SERVICE_NAME={service}
MODEL_PATH=models/model.joblib
LOG_LEVEL=INFO
LOG_FORMAT=human          # "json" for production (K8s), "human" for local dev

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─────────────────────────────────────────────
# MLflow
# ─────────────────────────────────────────────
MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_TRACKING_URI=http://mlflow:5000      # Docker Compose / K8s

# ─────────────────────────────────────────────
# OpenTelemetry (optional)
# ─────────────────────────────────────────────
OTEL_ENABLED=false
# OTEL_SERVICE_NAME={service}
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ─────────────────────────────────────────────
# Cloud (uncomment for your provider)
# ─────────────────────────────────────────────
# GCP
# GCP_PROJECT_ID=your-gcp-project
# GCS_MODEL_BUCKET=your-project-ml-models
# GCS_DATA_BUCKET=your-project-ml-data

# AWS
# AWS_REGION=us-east-1
# S3_MODEL_BUCKET=your-project-ml-models
# S3_DATA_BUCKET=your-project-ml-data

# ─────────────────────────────────────────────
# DVC Remote (optional)
# ─────────────────────────────────────────────
# DVC_REMOTE=gcs://your-bucket/dvc
# AWS_ACCESS_KEY_ID=your_key           # Only for local dev, use IRSA in K8s
# AWS_SECRET_ACCESS_KEY=your_secret
